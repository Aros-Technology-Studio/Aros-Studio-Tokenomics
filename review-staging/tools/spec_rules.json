{
  "terminology": {
    "forbidden": [
      "reward",
      "rewards",
      "Reward",
      "woзнагражд",
      "stake-to-validate"
    ],
    "allowed": [
      "payment",
      "payments",
      "payout",
      "settlement",
      "оплата",
      "выплата",
      "расчёт"
    ]
  },
  "logic": {
    "must_have_markers": [
      "payment_rate",
      "qos_multiplier",
      "tx_weight",
      "risk_adjustment",
      "settle_payments",
      "PoT",
      "Dynamic Fee Distribution"
    ],
    "audit_markers": [
      "rollback",
      "checkpoint",
      "audit",
      "journal",
      "state hash",
      "append-only"
    ],
    "kyc_markers": [
      "KYC",
      "AML",
      "compliance"
    ],
    "kyc_require": [
      "region",
      "jurisdiction",
      "retention"
    ],
    "time_markers": [
      "syncClock",
      "TTL",
      "time drift",
      "heartbeat",
      "nonce"
    ],
    "ttl_max_seconds": 120,
    "crypto_markers": [
      "signature",
      "ECDSA",
      "challenge-response",
      "nonce",
      "hash",
      "quorum"
    ],
    "non_speculative_forbidden": [
      "staking rewards"
    ],
    "layer_cross_refs": [
      {
        "if_any": [
          "PoT",
          "payment_rate"
        ],
        "then_any_in_files": [
          "07_processing_layer/tx_journal_writer.md",
          "07_processing_layer/tx_audit_log_format.md"
        ]
      },
      {
        "if_any": [
          "rollback"
        ],
        "then_any_in_files": [
          "07_processing_layer/tx_rollback_strategy.md"
        ]
      },
      {
        "if_any": [
          "KYC",
          "AML"
        ],
        "then_any_in_files": [
          "05_bridge_layer/kyc_aml_interface_bridge.md"
        ]
      }
    ]
  },
  "docs_style": {
    "forbidden_markers": [
      "TODO",
      "FIXME",
      "TBD",
      "???",
      "ВРЕМЕННО"
    ],
    "language_mixed_threshold": 0.20,
    "require_h1": true,
    "check_mermaid": true
  },
  "scoring": {
    "overall_threshold": 75.0,
    "weights": {
      "terminology": 2,
      "pot_logic": 3,
      "audit_rollback": 2,
      "kyc_link": 2,
      "time_sync": 2,
      "crypto_link": 2,
      "non_speculative": 2,
      "cross_layer_refs": 2,
      "doc_style": 1
    },
    "hard_fail": [
      "terminology_forbidden",
      "contradiction_rollback",
      "json_invalid"
    ]
  }
}