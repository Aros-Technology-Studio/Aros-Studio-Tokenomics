{
  "name": "aros-paradigm-ast",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint . --ext .ts -c .eslintrc.json",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier -c .",
    "format:fix": "prettier -w .",
    "generate:client": "npx @openapitools/openapi-generator-cli generate -i docs/api/openapi.yaml -g typescript-fetch -o client",
    "prepare": "npx husky install",
    "test": "jest",
    "check:prohibitions": "bash scripts/check-prohibitions.sh",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest --config ./tests/jest-e2e.json",
    "test:nodechain": "jest tests/unit/nodechain/**/*.spec.ts",
    "fix:ci": "ts-node scripts/fix-ci.ts",
    "fix:ci:dry": "ts-node scripts/fix-ci.ts --dry-run",
    "audit:full": "ts-node scripts/nightly-audit.ts",
    "agents:status": "ts-node scripts/agents-status.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.4.22",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/typeorm": "^10.0.1",
    "bullmq": "^5.66.4",
    "cbor-x": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "ethers": "^6.16.0",
    "ioredis": "^5.3.2",
    "js-sha3": "^0.9.3",
    "kafkajs": "^2.2.4",
    "nest-winston": "^1.9.4",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/cron": "^2.0.1",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.3.1",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "sqlite3": "^5.1.7",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.1.3"
  }
}
