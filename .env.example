# Example environment variables

# --- App ---
PORT=3000
# KILL_SWITCH=true

# --- NodeChain ledger (Phase 1.2) ---
# memory | file | rocksdb
LEDGER_BACKEND=memory
# Used when LEDGER_BACKEND=file or rocksdb
LEDGER_PATH=./data/nodechain
# 32-byte key as 64 hex chars (required in production for sensitive payloads)
# NODECHAIN_AT_REST_KEY=

# --- Postgres index mirror only (never source of truth) ---
# Leave unset to disable mirror
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/aros_ast
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=aros_ast

# --- Portal edge → core ---
# CORE_API_URL=http://localhost:3000/v1

# --- Release Phase config keys (numbers only in env, not hard-coded in canon) ---
# RELEASE_THRESHOLD=1
# RELEASE_TARGET=0.1
