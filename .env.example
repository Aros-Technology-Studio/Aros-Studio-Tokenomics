# AST runtime (copy to .env — never commit secrets)

# Journal
AST_JOURNAL_ENGINE=rocksdb
AST_JOURNAL_DIR=data/journal-rocks
AST_VERIFY_EVERY_N=5

# Kill-switch (set true for read-only)
KILL_SWITCH=false

# HTTP core (when enabled)
PORT=3000
NODE_ENV=local

# Institutional Portal edge
PORTAL_PORT=3100
NEXT_PUBLIC_PORTAL_API_URL=http://localhost:3100
# Portal → Core Orchestrator API
CORE_API_URL=http://localhost:3000
PORTAL_CORE_HANDOFF=true

# Release Phase (config-only thresholds)
RELEASE_THRESHOLD=0
RELEASE_TARGET=0

# Keys: memory | file | hsm (prod: hsm)
AST_KEY_PROVIDER=file
# AST_HSM_MASTER_KEY= # 64 hex chars for soft-HSM

# L3 LLM panel (optional; default policy agents)
# AST_L3_USE_LLM=0
# AST_L3_LLM_PROVIDER=mock
# AST_L3_LLM_BASE_URL=
# AST_L3_LLM_API_KEY=
# AST_L3_LLM_MODEL=

# Institution auth (prod: AST_REQUIRE_INSTITUTION_AUTH=1)
# AST_REQUIRE_INSTITUTION_AUTH=0
# AST_INSTITUTION_TOKEN=demo-institution-token

# Postgres index mirror (not SoT)
DATABASE_URL=postgres://ast:ast@localhost:5432/ast_index

