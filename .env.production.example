# Production secrets — copy to .env.production (never commit real values)
# docker compose -f docker-compose.prod.yml --env-file .env.production up --build -d

AST_IMAGE_TAG=1.1.0
NODE_ENV=production

# Core
AST_JOURNAL_ENGINE=file
AST_KEY_PROVIDER=file
KILL_SWITCH=false
AST_REQUIRE_INSTITUTION_AUTH=1
# Shared secret portal→core (must match an institution token or dedicated core secret)
AST_INSTITUTION_TOKEN=change-me-core-shared-secret

# Portal institutions (JSON array) — REQUIRED for real login
# Example single institution:
AST_INSTITUTION_SECRETS_JSON=[{"institutionId":"YOURBANK","displayName":"Your Bank","token":"change-me-long-random-token","allowlisted":true}]

# Never enable in production public deploy:
AST_ALLOW_DEMO=0

# Browser → edge (empty = same-origin rewrites if UI proxies /v1)
NEXT_PUBLIC_PORTAL_API_URL=http://YOUR_HOST:3100

CORE_PUBLISH_PORT=3000
PORTAL_EDGE_PUBLISH_PORT=3100
PORTAL_UI_PUBLISH_PORT=3200
